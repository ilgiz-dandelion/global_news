    "ax.set_title('Sentiment Distribution per Cluster', fontsize=12, fontweight='bold')\n",
    "ax.set_xlabel('Percentage (%)')\n",
    "ax.set_ylabel('Cluster')\n",
    "ax.legend(title='Sentiment', bbox_to_anchor=(1.02, 1), loc='upper left')\n",
    "plt.tight_layout()\n",
    "plt.savefig('../outputs/cluster_sentiment.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
