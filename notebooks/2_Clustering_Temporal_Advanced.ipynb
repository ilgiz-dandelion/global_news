    "original_data = pd.read_csv('../rating.csv')\n",
    "df_temporal = df.copy()\n",
    "\n",
    "title_to_date = dict(zip(original_data['title'], original_data['published_at']))\n",
    "df_temporal['published_at'] = df_temporal['title'].map(title_to_date)\n",
    "df_temporal['published_at'] = pd.to_datetime(df_temporal['published_at'], errors='coerce')\n",
    "df_temporal = df_temporal.dropna(subset=['published_at'])\n",
    "df_temporal['date'] = df_temporal['published_at'].dt.date\n",
    "\n",
    "print(f'Temporal data shape: {df_temporal.shape}')\n",
    "print(f'Date range: {df_temporal[\"published_at\"].min()} to {df_temporal[\"published_at\"].max()}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "sentiment_score_map = {'Negative': -1, 'Neutral': 0, 'Positive': 1}\n",
    "df_temporal['sentiment_score'] = df_temporal['title_sentiment'].map(sentiment_score_map)\n",
    "\n",
    "daily_sentiment = df_temporal.groupby('date').agg({\n",
    "    'sentiment_score': 'mean',\n",
    "    'title': 'count'\n",
    "}).rename(columns={'title': 'article_count'})\n",
    "daily_sentiment.index = pd.to_datetime(daily_sentiment.index)\n",
    "daily_sentiment['sentiment_ma7'] = daily_sentiment['sentiment_score'].rolling(7, min_periods=1).mean()\n",
    "\n",
    "fig, axes = plt.subplots(2, 1, figsize=(14, 10))\n",
    "\n",
    "ax1 = axes[0]\n",
    "ax1.plot(daily_sentiment.index, daily_sentiment['sentiment_ma7'], 'b-', linewidth=2)\n",
    "ax1.axhline(y=0, color='gray', linestyle='--', alpha=0.5)\n",
    "ax1.fill_between(daily_sentiment.index, daily_sentiment['sentiment_ma7'], 0, \n",
    "                 where=daily_sentiment['sentiment_ma7'] > 0, alpha=0.3, color='green')\n",
    "ax1.fill_between(daily_sentiment.index, daily_sentiment['sentiment_ma7'], 0, \n",
    "                 where=daily_sentiment['sentiment_ma7'] < 0, alpha=0.3, color='red')\n",
    "ax1.set_title('Daily Sentiment Trend (7-day Moving Average)', fontsize=14, fontweight='bold')\n",
    "ax1.set_xlabel('Date')\n",
    "ax1.set_ylabel('Sentiment Score')\n",
    "ax1.xaxis.set_major_formatter(mdates.DateFormatter('%b %d'))\n",
    "ax1.xaxis.set_major_locator(mdates.WeekdayLocator(interval=1))\n",
    "plt.setp(ax1.xaxis.get_majorticklabels(), rotation=45)\n",
    "\n",
    "ax2 = axes[1]\n",
    "ax2.bar(daily_sentiment.index, daily_sentiment['article_count'], color='steelblue', alpha=0.7)\n",
    "ax2.set_title('Daily Publication Volume', fontsize=14, fontweight='bold')\n",
    "ax2.set_xlabel('Date')\n",
    "ax2.set_ylabel('Number of Articles')\n",
    "ax2.xaxis.set_major_formatter(mdates.DateFormatter('%b %d'))\n",
    "ax2.xaxis.set_major_locator(mdates.WeekdayLocator(interval=1))\n",
    "plt.setp(ax2.xaxis.get_majorticklabels(), rotation=45)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../outputs/daily_sentiment_trend.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
