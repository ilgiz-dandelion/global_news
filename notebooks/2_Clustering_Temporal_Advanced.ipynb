   "metadata": {},
   "outputs": [],
   "source": [
    "hdbscan_clusterer = HDBSCAN(min_cluster_size=100, min_samples=10, metric='euclidean')\n",
    "cluster_labels_hdbscan = hdbscan_clusterer.fit_predict(embeddings_10d)\n",
    "\n",
    "with open('../models/hdbscan_model.pkl', 'wb') as f:\n",
    "    pickle.dump(hdbscan_clusterer, f)\n",
    "\n",
    "n_clusters_hdbscan = len(set(cluster_labels_hdbscan)) - (1 if -1 in cluster_labels_hdbscan else 0)\n",
    "n_noise = (cluster_labels_hdbscan == -1).sum()\n",
    "print(f'HDBSCAN found {n_clusters_hdbscan} clusters')\n",
    "print(f'Noise points: {n_noise} ({n_noise/len(cluster_labels_hdbscan)*100:.1f}%)')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, ax = plt.subplots(figsize=(14, 8))\n",
    "\n",
    "scatter = ax.scatter(embeddings_2d[:, 0], embeddings_2d[:, 1], \n",
    "                    c=cluster_labels_hdbscan, cmap='tab20', alpha=0.5, s=5)\n",
    "ax.set_title('HDBSCAN Clustering', fontsize=14, fontweight='bold')\n",
    "ax.set_xlabel('UMAP 1')\n",
    "ax.set_ylabel('UMAP 2')\n",
    "plt.colorbar(scatter, label='Cluster (-1 = noise)')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../outputs/umap_hdbscan.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
