   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.dates as mdates\n",
    "import seaborn as sns\n",
    "import pickle\n",
    "import json\n",
    "import warnings\n",
    "import os\n",
    "from datetime import datetime\n",
    "from collections import Counter\n",
    "\n",
    "import torch\n",
    "from torch.utils.data import Dataset\n",
    "from transformers import (\n",
    "    AutoTokenizer,\n",
    "    AutoModelForSequenceClassification,\n",
    "    TrainingArguments,\n",
    "    Trainer,\n",
    "    EarlyStoppingCallback\n",
    ")\n",
    "\n",
    "import umap\n",
    "from sklearn.cluster import KMeans\n",
    "from sklearn.metrics import silhouette_score\n",
    "from sklearn.feature_extraction.text import CountVectorizer\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.ensemble import VotingClassifier\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.metrics import accuracy_score, f1_score, classification_report, confusion_matrix, ConfusionMatrixDisplay\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "import scipy.sparse as sp\n",
    "\n",
    "from sentence_transformers import SentenceTransformer\n",
    "from bertopic import BERTopic\n",
    "from hdbscan import HDBSCAN\n",
    "\n",
    "warnings.filterwarnings('ignore')\n",
    "plt.style.use('seaborn-v0_8-whitegrid')\n",
    "plt.rcParams['figure.figsize'] = (12, 6)\n",
    "\n",
    "os.makedirs('../outputs', exist_ok=True)\n",
    "os.makedirs('../models', exist_ok=True)\n",
    "\n",
    "colors = {'Positive': '#2ecc71', 'Neutral': '#3498db', 'Negative': '#e74c3c'}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df = pd.read_csv('../outputs/df_processed.csv')\n",
    "embeddings = np.load('../outputs/embeddings_minilm.npy')\n",
    "\n",
    "with open('../models/sentiment_mapping.pkl', 'rb') as f:\n",
    "    sentiment_maps = pickle.load(f)\n",
    "    sentiment_mapping = sentiment_maps['forward']\n",
    "    sentiment_mapping_reverse = sentiment_maps['reverse']\n",
    "\n",
    "print(f'Dataset shape: {df.shape}')\n",
    "print(f'Embeddings shape: {embeddings.shape}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "reducer_2d = umap.UMAP(n_components=2, random_state=42, n_neighbors=15, min_dist=0.1, metric='cosine')\n",
    "embeddings_2d = reducer_2d.fit_transform(embeddings)\n",
    "print(f'2D embeddings shape: {embeddings_2d.shape}')\n",
    "np.save('../outputs/embeddings_umap_2d.npy', embeddings_2d)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "reducer_10d = umap.UMAP(n_components=10, random_state=42, n_neighbors=15, min_dist=0.0, metric='cosine')\n",
    "embeddings_10d = reducer_10d.fit_transform(embeddings)\n",
    "print(f'10D embeddings shape: {embeddings_10d.shape}')\n",
    "np.save('../outputs/embeddings_umap_10d.npy', embeddings_10d)\n",
    "with open('../models/umap_model.pkl', 'wb') as f:\n",
    "    pickle.dump(reducer_2d, f)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, ax = plt.subplots(figsize=(14, 8))\n",
    "\n",
    "for sentiment, color in colors.items():\n",
    "    mask = df['title_sentiment'] == sentiment\n",
    "    ax.scatter(embeddings_2d[mask, 0], embeddings_2d[mask, 1], \n",
    "               c=color, label=sentiment, alpha=0.5, s=5)\n",
    "\n",
    "ax.set_title('UMAP Projection Colored by Sentiment', fontsize=14, fontweight='bold')\n",
    "ax.set_xlabel('UMAP 1')\n",
    "ax.set_ylabel('UMAP 2')\n",
    "ax.legend(markerscale=3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../outputs/umap_sentiment.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "k_range = range(2, 11)\n",
    "inertias = []\n",
    "silhouette_scores = []\n",
    "\n",
    "for k in k_range:\n",
    "    kmeans = KMeans(n_clusters=k, random_state=42, n_init=10)\n",
    "    labels = kmeans.fit_predict(embeddings_10d)\n",
    "    inertias.append(kmeans.inertia_)\n",
    "    silhouette_scores.append(silhouette_score(embeddings_10d, labels))\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "axes[0].plot(k_range, inertias, 'bo-', linewidth=2, markersize=8)\n",
    "axes[0].set_title('Elbow Method', fontsize=12, fontweight='bold')\n",
    "axes[0].set_xlabel('Number of Clusters (k)')\n",
    "axes[0].set_ylabel('Inertia')\n",
    "axes[0].set_xticks(list(k_range))\n",
    "\n",
    "axes[1].plot(k_range, silhouette_scores, 'go-', linewidth=2, markersize=8)\n",
    "axes[1].set_title('Silhouette Score', fontsize=12, fontweight='bold')\n",
    "axes[1].set_xlabel('Number of Clusters (k)')\n",
    "axes[1].set_ylabel('Silhouette Score')\n",
    "axes[1].set_xticks(list(k_range))\n",
    "best_k = list(k_range)[np.argmax(silhouette_scores)]\n",
    "axes[1].axvline(best_k, color='red', linestyle='--', label=f'Best k={best_k}')\n",
    "axes[1].legend()\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../outputs/cluster_optimization.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "optimal_k = 5\n",
    "kmeans_final = KMeans(n_clusters=optimal_k, random_state=42, n_init=10)\n",
    "cluster_labels_kmeans = kmeans_final.fit_predict(embeddings_10d)\n",
    "\n",
    "df['kmeans_cluster'] = cluster_labels_kmeans\n",
    "df['umap_x'] = embeddings_2d[:, 0]\n",
    "df['umap_y'] = embeddings_2d[:, 1]\n",
    "\n",
    "with open('../models/kmeans_model.pkl', 'wb') as f:\n",
    "    pickle.dump(kmeans_final, f)\n",
    "\n",
    "print(f'Cluster distribution:')\n",
    "print(df['kmeans_cluster'].value_counts().sort_index())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, ax = plt.subplots(figsize=(14, 8))\n",
    "\n",
    "scatter = ax.scatter(embeddings_2d[:, 0], embeddings_2d[:, 1], \n",
    "                    c=cluster_labels_kmeans, cmap='tab10', alpha=0.5, s=5)\n",
    "ax.set_title(f'KMeans Clustering (k={optimal_k})', fontsize=14, fontweight='bold')\n",
    "ax.set_xlabel('UMAP 1')\n",
    "ax.set_ylabel('UMAP 2')\n",
    "plt.colorbar(scatter, label='Cluster')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../outputs/umap_kmeans.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
