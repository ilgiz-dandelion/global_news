  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_top_keywords(texts, n=10):\n",
    "    vectorizer = CountVectorizer(max_features=1000, stop_words='english', ngram_range=(1, 2))\n",
    "    X = vectorizer.fit_transform(texts)\n",
    "    words = vectorizer.get_feature_names_out()\n",
    "    counts = X.sum(axis=0).A1\n",
    "    top_idx = counts.argsort()[-n:][::-1]\n",
    "    return [(words[i], counts[i]) for i in top_idx]\n",
    "\n",
    "cluster_names = {}\n",
    "for cluster in range(optimal_k):\n",
    "    cluster_titles = df[df['kmeans_cluster'] == cluster]['title_processed'].tolist()\n",
    "    top_kw = get_top_keywords(cluster_titles)\n",
    "    print(f'Cluster {cluster}: {[kw[0] for kw in top_kw[:5]]}')\n",
    "    cluster_names[cluster] = ', '.join([kw[0] for kw in top_kw[:3]])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "cluster_sentiment = df.groupby(['kmeans_cluster', 'title_sentiment']).size().unstack(fill_value=0)\n",
