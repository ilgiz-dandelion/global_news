   "source": [
    "df_temporal['day_of_week'] = df_temporal['published_at'].dt.day_name()\n",
    "df_temporal['hour'] = df_temporal['published_at'].dt.hour\n",
    "\n",
    "dow_order = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday']\n",
    "dow_sentiment = df_temporal.groupby('day_of_week')['sentiment_score'].mean().reindex(dow_order)\n",
    "hour_sentiment = df_temporal.groupby(['hour', 'title_sentiment']).size().unstack(fill_value=0)\n",
    "hour_sentiment_pct = hour_sentiment.div(hour_sentiment.sum(axis=1), axis=0) * 100\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "colors_dow = ['#e74c3c' if x < 0 else '#2ecc71' for x in dow_sentiment.values]\n",
    "axes[0].bar(dow_sentiment.index, dow_sentiment.values, color=colors_dow)\n",
    "axes[0].axhline(0, color='gray', linestyle='--', alpha=0.5)\n",
    "axes[0].set_title('Sentiment by Day of Week', fontsize=12, fontweight='bold')\n",
    "axes[0].set_ylabel('Mean Sentiment Score')\n",
    "axes[0].tick_params(axis='x', rotation=45)\n",
    "\n",
    "for sentiment in ['Negative', 'Neutral', 'Positive']:\n",
    "    if sentiment in hour_sentiment_pct.columns:\n",
