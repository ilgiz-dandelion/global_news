    "    texts_bert, labels_bert, test_size=0.3, stratify=labels_bert, random_state=42\n",
    ")\n",
    "X_val_bert, X_test_bert, y_val_bert, y_test_bert = train_test_split(\n",
    "    X_temp_bert, y_temp_bert, test_size=0.5, stratify=y_temp_bert, random_state=42\n",
    ")\n",
    "\n",
